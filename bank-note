/*---------------------------------------------------
ثبت جدول دیتابیس (هنگام فعال‌سازی افزونه)
---------------------------------------------------*/
function bof_create_table() {
    global $wpdb;
    $table_name = $wpdb->prefix . 'banknote_orders';
    $charset_collate = $wpdb->get_charset_collate();

    $sql = "CREATE TABLE $table_name (
        id mediumint(9) NOT NULL AUTO_INCREMENT,
        fullname text NOT NULL,
        phone text NOT NULL,
        order_type text NOT NULL,
        currency_type text NOT NULL,
        is_read tinyint(1) DEFAULT 0 NOT NULL,
        created_at datetime DEFAULT CURRENT_TIMESTAMP NOT NULL,
        PRIMARY KEY  (id)
    ) $charset_collate;";

    require_once(ABSPATH . 'wp-admin/includes/upgrade.php');
    dbDelta($sql);
}

register_activation_hook(__FILE__, 'bof_create_table');

/*---------------------------------------------------
ثبت سفارش Ajax
---------------------------------------------------*/
function bof_save_order() {
    global $wpdb;
    $table_name = $wpdb->prefix . 'banknote_orders';

    $fullname      = isset($_POST['fullname']) ? sanitize_text_field($_POST['fullname']) : '';
    $phone         = isset($_POST['phone']) ? sanitize_text_field($_POST['phone']) : '';
    $order_type    = isset($_POST['order_type']) ? sanitize_text_field($_POST['order_type']) : '';
    $currency_type = isset($_POST['currency_type']) ? sanitize_text_field($_POST['currency_type']) : '';

    if(empty($fullname) || empty($phone) || empty($order_type) || empty($currency_type)){
        wp_send_json_error('اطلاعات ناقص است');
    }

    $insert = $wpdb->insert(
        $table_name,
        array(
            'fullname'      => $fullname,
            'phone'         => $phone,
            'order_type'    => $order_type,
            'currency_type' => $currency_type,
            'is_read'       => 0,
            'created_at'    => current_time('mysql')
        ),
        array('%s','%s','%s','%s','%d','%s')
    );

    if($insert){
        wp_send_json_success('ثبت شد');
    }else{
        wp_send_json_error('خطا در ذخیره داده‌ها در دیتابیس');
    }
}

add_action('wp_ajax_bof_save_order', 'bof_save_order');
add_action('wp_ajax_nopriv_bof_save_order', 'bof_save_order');

