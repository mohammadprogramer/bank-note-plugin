/*---------------------------------------------------
منوی پیشخوان
---------------------------------------------------*/
function bof_admin_menu() {
    global $wpdb;
    $table_name = $wpdb->prefix . 'banknote_orders';
    
    if($wpdb->get_var("SHOW TABLES LIKE '$table_name'") == $table_name) {
        $count = $wpdb->get_var("SELECT COUNT(id) FROM $table_name WHERE is_read = 0");
    } else {
        $count = 0;
    }

    $menu_title = 'سفارشات اسکناس';

    if($count > 0){
        $menu_title .= ' <span class="awaiting-mod update-plugins count-' . $count . '"><span class="plugin-count">' . $count . '</span></span>';
    }

    add_menu_page(
        'سفارشات اسکناس',
        $menu_title,
        'manage_options',
        'banknote-orders',
        'bof_orders_page',
        'dashicons-money-alt',
        7
    );
}

add_action('admin_menu', 'bof_admin_menu');

/*---------------------------------------------------
صفحه سفارشات در پیشخوان
---------------------------------------------------*/
function bof_orders_page() {

    global $wpdb;
    $table_name = $wpdb->prefix . 'banknote_orders';

    if($wpdb->get_var("SHOW TABLES LIKE '$table_name'") != $table_name) {

        echo '<div class="wrap">
                <h1>خطا</h1>
                <p>جدول دیتابیس ساخته نشده است.</p>
              </div>';

        return;
    }

    /*---------------------------------------------------
    خوانده شده
    ---------------------------------------------------*/
    if (isset($_GET['mark_read']) && isset($_GET['order_id'])) {

        $order_id = intval($_GET['order_id']);

        $wpdb->update(
            $table_name,
            array('is_read' => 1),
            array('id' => $order_id),
            array('%d'),
            array('%d')
        );

        echo '<div class="notice notice-success is-dismissible">
                <p>سفارش خوانده شد.</p>
              </div>';
    }

    /*---------------------------------------------------
    همه خوانده شوند
    ---------------------------------------------------*/
    if (isset($_GET['mark_all_read'])) {

        $wpdb->update(
            $table_name,
            array('is_read' => 1),
            array('is_read' => 0),
            array('%d'),
            array('%d')
        );

        echo '<div class="notice notice-success is-dismissible">
                <p>همه سفارشات خوانده شدند.</p>
              </div>';
    }

    /*---------------------------------------------------
    حذف سفارش
    ---------------------------------------------------*/
    if (isset($_GET['delete_order']) && isset($_GET['order_id'])) {

        $order_id = intval($_GET['order_id']);

        $wpdb->delete(
            $table_name,
            array('id' => $order_id),
            array('%d')
        );

        echo '<div class="notice notice-success is-dismissible">
                <p>سفارش حذف شد.</p>
              </div>';
    }

    /*---------------------------------------------------
    ذخیره ویرایش
    ---------------------------------------------------*/
    if (isset($_POST['update_order'])) {

        $order_id = intval($_POST['order_id']);

        $wpdb->update(
            $table_name,
            array(
                'fullname'      => sanitize_text_field($_POST['fullname']),
                'phone'         => sanitize_text_field($_POST['phone']),
                'order_type'    => sanitize_text_field($_POST['order_type']),
                'currency_type' => sanitize_text_field($_POST['currency_type']),
            ),
            array('id' => $order_id),
            array('%s','%s','%s','%s'),
            array('%d')
        );

        echo '<div class="notice notice-success is-dismissible">
                <p>سفارش ویرایش شد.</p>
              </div>';
    }

    $orders = $wpdb->get_results(
        "SELECT * FROM $table_name ORDER BY created_at DESC"
    );

    ?>

    <div class="wrap">

        <h1 style="margin-bottom:20px;">

            لیست درخواست‌های اسکناس

            <a href="?page=banknote-orders&mark_all_read=1"
               class="page-title-action">

               تبدیل همه به خوانده شده

            </a>

        </h1>

        <?php
        /*---------------------------------------------------
        فرم ویرایش
        ---------------------------------------------------*/
        if (isset($_GET['edit_order'])) {

            $edit_id = intval($_GET['edit_order']);

            $edit_order = $wpdb->get_row(
                "SELECT * FROM $table_name WHERE id = $edit_id"
            );

            if ($edit_order):
        ?>

